# Copy this file to .env for local development, or set these as
# Environment Variables in the Render dashboard for deployment.

# From Supabase: Project Settings -> Database -> Connection string (URI, "Session pooler" mode recommended for Render)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Any long random string. Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# How long login sessions last, in minutes. 10080 = 7 days.
JWT_EXPIRES_MINUTES=10080

# Comma-separated list of allowed frontend origins (no trailing slash).
# Use "*" only for early testing — restrict this before going live.
FRONTEND_ORIGINS=*

# Added later, once Stripe checkout is wired up server-side.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
